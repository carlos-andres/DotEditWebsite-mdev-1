---
interface Props {
  src: string;
  alt: string;
  class?: string;
}

const { src, alt, class: className = '' } = Astro.props;
const webpSrc = src.replace(/\.png$/, '.webp');
---

<div
  class:list={['screenshot-wrapper reveal mx-auto max-w-[1100px] px-6', className]}
  data-parallax
>
  <div class="relative">
    <picture>
      <source srcset={webpSrc} type="image/webp" />
      <img
        src={src}
        alt={alt}
        width="1100"
        height="700"
        class="w-full h-auto"
        loading="lazy"
        decoding="async"
      />
    </picture>
  </div>
</div>
