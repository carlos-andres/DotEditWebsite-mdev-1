---
interface Props {
  src: string;
  alt: string;
  class?: string;
}

const { src, alt, class: className = '' } = Astro.props;
---

<div
  class:list={['screenshot-wrapper reveal mx-auto max-w-[1100px] px-6', className]}
  data-parallax
>
  <div class="relative">
    <img
      src={src}
      alt={alt}
      class="w-full rounded-xl"
      style="box-shadow: 0 24px 48px rgba(0,0,0,0.12), 0 8px 16px rgba(0,0,0,0.06);"
      loading="lazy"
      decoding="async"
    />
    <!-- Shadow overlay for dark mode depth -->
    <div class="absolute inset-0 rounded-xl ring-1 ring-inset ring-black/5 dark:ring-white/5 pointer-events-none" aria-hidden="true"></div>
  </div>
</div>
