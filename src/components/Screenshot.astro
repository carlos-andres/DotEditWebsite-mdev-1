---
interface Props {
  src: string;
  alt: string;
  class?: string;
}

const { src, alt, class: className = '' } = Astro.props;
---

<div
  class:list={['screenshot-wrapper reveal mx-auto max-w-[1100px] px-6', className]}
  data-parallax
>
  <div class="relative">
    <img
      src={src}
      alt={alt}
      width="1100"
      height="700"
      class="w-full h-auto"
      loading="lazy"
      decoding="async"
    />
  </div>
</div>
